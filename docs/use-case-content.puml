@startuml AliasUseCaseContent

title Alias — Use Case Diagram (Частина 1: Контент та обліковий запис)

' ===========================================================================
' Styling
' ===========================================================================
skinparam backgroundColor #FFFFFF
skinparam DefaultFontName "Segoe UI"
skinparam DefaultFontSize 12
skinparam shadowing false
skinparam Nodesep 18
skinparam Ranksep 32
skinparam roundCorner 6
skinparam linetype ortho

skinparam actor {
    BorderColor #34495E
    BackgroundColor #FDFEFE
    FontStyle bold
}

skinparam usecase {
    BorderColor #2E7D32
    BackgroundColor #E8F5E9
    FontColor #1B1B1B
}

skinparam package {
    BorderColor #2E7D32
    BackgroundColor #F7FBF7
    FontStyle bold
    FontColor #1B5E20
}

skinparam ArrowColor #2C3E50
skinparam ArrowFontColor #2C3E50
skinparam ArrowThickness 1.1

left to right direction

' ===========================================================================
' Actors
' ===========================================================================
actor "Гість"      as Guest
actor "Користувач" as User

User --|> Guest


' ===========================================================================
' 1. Обліковий запис та авторизація
' ===========================================================================
rectangle "Обліковий запис та авторизація" as PKG_Auth {
    together {
        usecase "Увійти через Google"    as UC_GoogleLogin
        usecase "Зареєструватися"        as UC_Register
        usecase "Підтвердити email"      as UC_VerifyEmail
    }
    usecase "Увійти (email/пароль)"  as UC_Login
    usecase "Відновити пароль"       as UC_ResetPwd
    usecase "Змінити пароль"         as UC_ChangePwd
    usecase "Видалити обл. запис"    as UC_DeleteAcc
    usecase "Оновити токени"         as UC_RefreshToken
}

Guest --> UC_Register
Guest --> UC_Login
Guest --> UC_GoogleLogin
Guest --> UC_ResetPwd
User  --> UC_VerifyEmail
User  --> UC_ChangePwd
User  --> UC_DeleteAcc
User  --> UC_RefreshToken

UC_Register    .right.> UC_VerifyEmail : <<extend>>
UC_GoogleLogin .right.> UC_Register    : <<extend>>


' ===========================================================================
' 2. Профіль користувача
' ===========================================================================
rectangle "Профіль користувача" as PKG_Profile {
    together {
        usecase "Завантажити аватар"   as UC_UploadAvatar
        usecase "Редагувати профіль"   as UC_EditProfile
    }
    usecase "Видалити аватар"      as UC_DeleteAvatar
    usecase "Переглянути профіль"  as UC_ViewProfile
}

User --> UC_EditProfile
User --> UC_UploadAvatar
User --> UC_DeleteAvatar
User --> UC_ViewProfile

UC_UploadAvatar .right.> UC_EditProfile : <<extend>>


' ===========================================================================
' 3. Набори карток
' ===========================================================================
rectangle "Набори карток" as PKG_Packs {
    usecase "Каталог наборів"      as UC_BrowsePacks
    usecase "Створити набір"       as UC_CreatePack
    usecase "Управляти картками"   as UC_ManageCards
    together {
        usecase "Обкладинка набору"    as UC_PackCover
        usecase "Редагувати метадані"  as UC_EditPack
    }
    together {
        usecase "Опублікувати набір"   as UC_PublishPack
        usecase "Активувати набір"     as UC_ActivatePack
    }
    usecase "Видалити/відновити"   as UC_TrashPack
    usecase "Оцінити набір"        as UC_RatePack
    usecase "У вибране"            as UC_SavePack
}

Guest --> UC_BrowsePacks
User  --> UC_CreatePack
User  --> UC_ManageCards
User  --> UC_EditPack
User  --> UC_PackCover
User  --> UC_ActivatePack
User  --> UC_PublishPack
User  --> UC_TrashPack
User  --> UC_RatePack
User  --> UC_SavePack

UC_PublishPack .right.> UC_ActivatePack : <<include>>
UC_PackCover   .right.> UC_EditPack     : <<extend>>


' ===========================================================================
' 4. Мапи
' ===========================================================================
rectangle "Мапи" as PKG_Maps {
    usecase "Каталог мап"          as UC_BrowseMaps
    together {
        usecase "Опублікувати мапу"    as UC_PublishMap
        usecase "Активувати мапу"      as UC_ActivateMap
        usecase "Налаштувати поля"     as UC_ConfigFields
        usecase "Створити мапу"        as UC_CreateMap
    }
    together {
        usecase "Обкладинка мапи"      as UC_MapCover
        usecase "Редагувати метадані"  as UC_EditMapMeta
    }
    usecase "Видалити/відновити"   as UC_TrashMap
    usecase "Оцінити мапу"         as UC_RateMap
    usecase "У вибране"            as UC_SaveMap
}

Guest --> UC_BrowseMaps
User  --> UC_CreateMap
User  --> UC_ConfigFields
User  --> UC_EditMapMeta
User  --> UC_MapCover
User  --> UC_ActivateMap
User  --> UC_PublishMap
User  --> UC_TrashMap
User  --> UC_RateMap
User  --> UC_SaveMap

UC_CreateMap   .right.> UC_ConfigFields : <<include>>
UC_ActivateMap .right.> UC_ConfigFields : <<include>>
UC_PublishMap  .right.> UC_ActivateMap  : <<include>>
UC_MapCover    .right.> UC_EditMapMeta  : <<extend>>


' ===========================================================================
' Layout (сітка 2×2):
'   Auth     | Packs
'   Profile  | Maps
'
'  Гість зверху, поруч з Auth і каталогами. User під ним — поруч з Profile.
' ===========================================================================
Guest       -[hidden]down-  User
PKG_Auth    -[hidden]right- PKG_Packs
PKG_Profile -[hidden]right- PKG_Maps
PKG_Auth    -[hidden]down-  PKG_Profile
PKG_Packs   -[hidden]down-  PKG_Maps


legend bottom
|= Актор       |= Роль |
| Гість        | Незареєстрований відвідувач сайту, переглядає каталоги, реєструється та входить |
| Користувач   | Авторизований власник профілю, створює та публікує набори карток і мапи |
endlegend

@enduml
