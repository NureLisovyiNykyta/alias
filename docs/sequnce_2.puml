@startuml sequence_websocket
' ============================================================
'   SEQUENCE DIAGRAM — WebSocket Connection Lifecycle
' ============================================================
skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 40

skinparam sequence {
    ArrowColor #37474F
    ArrowFontSize 40
    ArrowFontColor #37474F
    LifeLineBorderColor #78909C
    LifeLineBackgroundColor #ECEFF1
    ParticipantBorderColor #1565C0
    ParticipantBackgroundColor #E3F2FD
    ParticipantFontColor #0D47A1
    ParticipantFontSize 40
    ParticipantFontStyle bold
    ActorBorderColor #2E7D32
    ActorBackgroundColor #E8F5E9
    DividerBorderColor #90A4AE
    DividerBackgroundColor #ECEFF1
    DividerFontStyle bold
}

skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontSize 30
}

' =================== Participants ===================
actor       "Player"           as P      #E8F5E9
participant "ws/router.py"     as WR     #D5B3FF
participant "GameRepository"   as GR     #C8E6C9
database    "Redis"            as Redis  #E3F2FD
participant "ConnectionManager" as CM    #D5B3FF
actor       "Other Players\n(WS)" as OP  #F3E5F5

' =================== CONNECT ===================
== Підключення ==

P -> WR ++ #D5B3FF : WS /ws/rooms/{room_code}\n?token=<JWT>
    WR -> WR : get_ws_player_id(token)\n→ player_id

    WR -> GR ++ #C8E6C9 : get_room(room_code)
        GR -> Redis ++ : GET room:<code>
        return JSON
    return RoomStateJSON

    WR -> WR : validate:\nplayer_id ∈ room.players

    WR -> CM ++ #D5B3FF : connect(room_code, player_id, ws)
        CM -> CM : ws.accept()
        CM -> CM : _rooms[code][id] = ws
    return

    WR -> WR : room.players[id].is_online = True

    WR -> GR ++ #C8E6C9 : save_room(room)
        GR -> Redis ++ : SET room:<code>
        return OK
    return

    WR -> CM ++ #D5B3FF : send_personal(ws,\nServerEvent.room_state)
        CM -> P : send_text(room_state JSON)
    return

    WR ->> CM ++ #D5B3FF : broadcast_except(room_code,\nplayer_id, player_connected)
        CM ->> OP : send_text(JSON)\n<i>to all except sender</i>
    return

    |||
    ' =================== LISTEN LOOP ===================
    == Цикл прослуховування ==

    loop while connected
        P -> WR : receive_text()

        alt valid ClientEvent
            WR -> WR : ClientEvent.model_validate_json(data)
            note right : Обробка клієнтських подій\n(зарезервовано для\nмайбутніх механік)
        else invalid message
            WR -> CM ++ #D5B3FF : send_personal(ws,\nServerEvent.error)
                CM -> P : send_text(error JSON)
            return
        end
    end

    |||
    ' =================== DISCONNECT ===================
    == Від'єднання ==

    P ->x WR : WebSocketDisconnect

    WR -> CM : disconnect(room_code, player_id)
    note right of CM : _rooms[code].pop(id)\nif empty → del room

    WR -> GR ++ #C8E6C9 : get_room(room_code)
        GR -> Redis ++ : GET room:<code>
        return JSON
    return RoomStateJSON | None

    opt room exists & player in room
        WR -> WR : room.players[id].is_online = False

        WR -> GR ++ #C8E6C9 : save_room(room)
            GR -> Redis ++ : SET room:<code>
            return OK
        return

        WR ->> CM ++ #D5B3FF : broadcast(room_code,\nServerEvent.player_disconnected)
            CM ->> OP : send_text(JSON)
        return
    end

deactivate WR

@enduml