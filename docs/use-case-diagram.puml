@startuml AliasUseCaseDiagram

title Alias — Use Case Diagram

' ===========================================================================
' Styling
' ===========================================================================
skinparam backgroundColor #FFFFFF
skinparam DefaultFontName "Segoe UI"
skinparam DefaultFontSize 12
skinparam shadowing false

skinparam actor {
    BorderColor #34495E
    BackgroundColor #FDFEFE
    FontStyle bold
}

skinparam usecase {
    BorderColor #2E7D32
    BackgroundColor #E8F5E9
    FontColor #1B1B1B
}

skinparam package {
    BorderColor #2E7D32
    BackgroundColor #F7FBF7
    FontStyle bold
    FontColor #1B5E20
}

skinparam ArrowColor #555555
skinparam ArrowFontColor #555555

left to right direction

' ===========================================================================
' Actors
' ===========================================================================
actor "Гість\n(Guest)" as Guest
actor "Зареєстрований\nкористувач" as User
actor "Гравець\n(Player)" as Player
actor "Хост\n(Host)" as Host
actor "Ведучий\n(Explainer)" as Explainer

' Generalization: Зареєстрований успадковує можливості Гостя
User       --|> Guest
' Хост — це Зареєстрований користувач, який є також Гравцем (творцем лобі)
Host       --|> User
Host       --|> Player
' Ведучий — спеціальна роль Гравця, який зараз пояснює слова
Explainer  --|> Player


' ===========================================================================
' 1. Обліковий запис та авторизація
' ===========================================================================
rectangle "Обліковий запис та авторизація" as PKG_Auth {
    usecase "Зареєструватися"                  as UC_Register
    usecase "Увійти за email/паролем"          as UC_Login
    usecase "Увійти через Google"              as UC_GoogleLogin
    usecase "Підтвердити email"                as UC_VerifyEmail
    usecase "Відновити пароль"                 as UC_ResetPwd
    usecase "Змінити пароль"                   as UC_ChangePwd
    usecase "Видалити обліковий запис"         as UC_DeleteAcc
    usecase "Оновити токени доступу"           as UC_RefreshToken
}

Guest --> UC_Register
Guest --> UC_Login
Guest --> UC_GoogleLogin
Guest --> UC_ResetPwd
User  --> UC_VerifyEmail
User  --> UC_ChangePwd
User  --> UC_DeleteAcc
User  --> UC_RefreshToken

UC_Register    .> UC_VerifyEmail : <<extend>>
UC_GoogleLogin .> UC_Register    : <<extend>>


' ===========================================================================
' 2. Профіль користувача
' ===========================================================================
rectangle "Профіль користувача" as PKG_Profile {
    usecase "Редагувати профіль\n(нікнейм / аватар)"  as UC_EditProfile
    usecase "Завантажити власний аватар"              as UC_UploadAvatar
    usecase "Видалити аватар"                         as UC_DeleteAvatar
    usecase "Переглянути\nпублічний профіль"          as UC_ViewProfile
}

User --> UC_EditProfile
User --> UC_UploadAvatar
User --> UC_DeleteAvatar
User --> UC_ViewProfile

UC_UploadAvatar .> UC_EditProfile : <<extend>>


' ===========================================================================
' 3. Набори карток (Card Packs)
' ===========================================================================
rectangle "Набори карток" as PKG_Packs {
    usecase "Створити набір карток"           as UC_CreatePack
    usecase "Управляти картками\nв наборі"    as UC_ManageCards
    usecase "Редагувати метадані набору"      as UC_EditPack
    usecase "Завантажити обкладинку набору"   as UC_PackCover
    usecase "Активувати набір"                as UC_ActivatePack
    usecase "Опублікувати набір"              as UC_PublishPack
    usecase "Видалити/відновити набір"        as UC_TrashPack
    usecase "Оцінити набір"                   as UC_RatePack
    usecase "Зберегти набір\nу вибране"       as UC_SavePack
    usecase "Переглянути каталог\nнаборів"    as UC_BrowsePacks
}

User  --> UC_CreatePack
User  --> UC_ManageCards
User  --> UC_EditPack
User  --> UC_PackCover
User  --> UC_ActivatePack
User  --> UC_PublishPack
User  --> UC_TrashPack
User  --> UC_RatePack
User  --> UC_SavePack
Guest --> UC_BrowsePacks

UC_PublishPack .> UC_ActivatePack : <<include>>
UC_PackCover   .> UC_EditPack     : <<extend>>


' ===========================================================================
' 4. Мапи (Maps)
' ===========================================================================
rectangle "Мапи" as PKG_Maps {
    usecase "Створити мапу"                   as UC_CreateMap
    usecase "Налаштувати поля мапи"           as UC_ConfigFields
    usecase "Редагувати метадані мапи"        as UC_EditMap
    usecase "Завантажити обкладинку мапи"     as UC_MapCover
    usecase "Активувати мапу"                 as UC_ActivateMap
    usecase "Опублікувати мапу"               as UC_PublishMap
    usecase "Видалити/відновити мапу"         as UC_TrashMap
    usecase "Оцінити мапу"                    as UC_RateMap
    usecase "Зберегти мапу\nу вибране"        as UC_SaveMap
    usecase "Переглянути каталог мап"         as UC_BrowseMaps
}

User  --> UC_CreateMap
User  --> UC_ConfigFields
User  --> UC_EditMap
User  --> UC_MapCover
User  --> UC_ActivateMap
User  --> UC_PublishMap
User  --> UC_TrashMap
User  --> UC_RateMap
User  --> UC_SaveMap
Guest --> UC_BrowseMaps

UC_CreateMap   .> UC_ConfigFields : <<include>>
UC_ActivateMap .> UC_ConfigFields : <<include>>
UC_PublishMap  .> UC_ActivateMap  : <<include>>
UC_MapCover    .> UC_EditMap      : <<extend>>


' ===========================================================================
' 5. Лобі та команди
' ===========================================================================
rectangle "Лобі та команди" as PKG_Lobby {
    usecase "Створити лобі"                      as UC_CreateLobby
    usecase "Приєднатися до лобі\nяк гість"      as UC_JoinAsGuest
    usecase "Приєднатися до лобі\nяк користувач" as UC_JoinAsUser
    usecase "Створити команду"                   as UC_CreateTeam
    usecase "Редагувати команду"                 as UC_EditTeam
    usecase "Видалити команду"                   as UC_DeleteTeam
    usecase "Приєднатися до /\nпокинути команду" as UC_TeamJoinLeave
    usecase "Виганяти гравців\n(модерація)"      as UC_Kick
    usecase "Закрити лобі"                       as UC_CloseLobby
    usecase "Покинути лобі"                      as UC_LeaveLobby
}

Host   --> UC_CreateLobby
Guest  --> UC_JoinAsGuest
User   --> UC_JoinAsUser
Host   --> UC_CreateTeam
Host   --> UC_EditTeam
Host   --> UC_DeleteTeam
Player --> UC_TeamJoinLeave
Host   --> UC_Kick
Host   --> UC_CloseLobby
Player --> UC_LeaveLobby


' ===========================================================================
' 6. Ігровий процес
' ===========================================================================
rectangle "Ігровий процес" as PKG_Game {
    usecase "Розпочати гру"                       as UC_StartGame
    usecase "Розпочати свій хід\n(фаза PREPARE)"  as UC_StartTurn
    usecase "Відмічати картки\nGUESSED/FAILED"    as UC_GuessCards
    usecase "Підтвердити\nрезультати ходу"        as UC_ReviewTurn
    usecase "Вручну змінити рахунок"              as UC_AdjustScore
    usecase "Перезапустити хід"                   as UC_RestartTurn
    usecase "Бачити фінальний рахунок"            as UC_FinishGame
}

Host      --> UC_StartGame
Explainer --> UC_StartTurn
Explainer --> UC_GuessCards
Explainer --> UC_ReviewTurn
Host      --> UC_ReviewTurn
Host      --> UC_AdjustScore
Host      --> UC_RestartTurn
Player    --> UC_FinishGame

UC_ReviewTurn  .> UC_FinishGame  : <<extend>>
UC_RestartTurn .> UC_StartTurn   : <<extend>>


' ===========================================================================
' 7. Зв'язок у реальному часі
' ===========================================================================
rectangle "Зв'язок у реальному часі" as PKG_Realtime {
    usecase "Отримувати оновлення\nстану кімнати (WS)" as UC_RealtimeSync
    usecase "Перепідключитися до гри"                  as UC_Reconnect
    usecase "Спілкуватися у\nкомандному чаті"          as UC_TeamChat
    usecase "Спілкуватися у\nглобальному чаті"         as UC_GlobalChat
}

Player --> UC_RealtimeSync
Player --> UC_Reconnect
Player --> UC_TeamChat
Player --> UC_GlobalChat


' ===========================================================================
' Layout hints
' ===========================================================================
PKG_Auth     -[hidden]down- PKG_Profile
PKG_Profile  -[hidden]down- PKG_Packs
PKG_Packs    -[hidden]down- PKG_Maps
PKG_Maps     -[hidden]down- PKG_Lobby
PKG_Lobby    -[hidden]down- PKG_Game
PKG_Game     -[hidden]down- PKG_Realtime


' ===========================================================================
' Legend
' ===========================================================================
legend bottom
|= Актор |= Опис |
| Гість (Guest)               | Незареєстрований відвідувач сайту, може реєструватися, входити, переглядати публічні каталоги та грати як гість у лобі |
| Зареєстрований користувач   | Авторизований у системі, має профіль, може створювати мапи, набори карток, лобі, оцінювати контент |
| Гравець (Player)            | Будь-який учасник лобі (гість або зареєстрований), бере участь у грі, чатах |
| Хост (Host)                 | Творець лобі — зареєстрований користувач, який модерує кімнату та керує грою |
| Ведучий (Explainer)         | Гравець, чия команда зараз ходить — пояснює слова під час фази GUESSING |
endlegend

@enduml
