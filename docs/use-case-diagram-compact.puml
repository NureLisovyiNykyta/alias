@startuml AliasUseCaseDiagramCompact

title Alias — Use Case Diagram

' ===========================================================================
' Styling — компактна версія під A4 landscape
' ===========================================================================
skinparam backgroundColor #FFFFFF
skinparam DefaultFontName "Segoe UI"
skinparam DefaultFontSize 11
skinparam shadowing false
skinparam Nodesep 10
skinparam Ranksep 22
skinparam Padding 2
skinparam roundCorner 6
skinparam PackageTitleAlignment left

skinparam actor {
    BorderColor #34495E
    BackgroundColor #FDFEFE
    FontStyle bold
}

skinparam usecase {
    BorderColor #2E7D32
    BackgroundColor #E8F5E9
    FontColor #1B1B1B
}

skinparam package {
    BorderColor #2E7D32
    BackgroundColor #F7FBF7
    FontStyle bold
    FontColor #1B5E20
}

skinparam ArrowColor #555555
skinparam ArrowFontColor #555555

left to right direction

' ===========================================================================
' Actors (укорочені підписи)
' ===========================================================================
actor "Гість"         as Guest
actor "Користувач"    as User
actor "Гравець"       as Player
actor "Хост"          as Host
actor "Ведучий"       as Explainer

User       --|> Guest
Host       --|> User
Host       --|> Player
Explainer  --|> Player


' ===========================================================================
' 1. Обліковий запис та авторизація
' ===========================================================================
rectangle "Обліковий запис та авторизація" as PKG_Auth {
    usecase "Зареєструватися"           as UC_Register
    usecase "Увійти (email/пароль)"     as UC_Login
    usecase "Увійти через Google"       as UC_GoogleLogin
    usecase "Підтвердити email"         as UC_VerifyEmail
    usecase "Відновити пароль"          as UC_ResetPwd
    usecase "Змінити пароль"            as UC_ChangePwd
    usecase "Видалити обл. запис"       as UC_DeleteAcc
    usecase "Оновити токени"            as UC_RefreshToken
}

Guest --> UC_Register
Guest --> UC_Login
Guest --> UC_GoogleLogin
Guest --> UC_ResetPwd
User  --> UC_VerifyEmail
User  --> UC_ChangePwd
User  --> UC_DeleteAcc
User  --> UC_RefreshToken

UC_Register    .> UC_VerifyEmail : <<extend>>
UC_GoogleLogin .> UC_Register    : <<extend>>


' ===========================================================================
' 2. Профіль користувача
' ===========================================================================
rectangle "Профіль користувача" as PKG_Profile {
    usecase "Редагувати профіль"        as UC_EditProfile
    usecase "Завантажити аватар"        as UC_UploadAvatar
    usecase "Видалити аватар"           as UC_DeleteAvatar
    usecase "Переглянути профіль"       as UC_ViewProfile
}

User --> UC_EditProfile
User --> UC_UploadAvatar
User --> UC_DeleteAvatar
User --> UC_ViewProfile

UC_UploadAvatar .> UC_EditProfile : <<extend>>


' ===========================================================================
' 3. Набори карток
' ===========================================================================
rectangle "Набори карток" as PKG_Packs {
    usecase "Створити набір"            as UC_CreatePack
    usecase "Управляти картками"        as UC_ManageCards
    usecase "Редагувати метадані"       as UC_EditPack
    usecase "Обкладинка набору"         as UC_PackCover
    usecase "Активувати набір"          as UC_ActivatePack
    usecase "Опублікувати набір"        as UC_PublishPack
    usecase "Видалити/відновити"        as UC_TrashPack
    usecase "Оцінити набір"             as UC_RatePack
    usecase "У вибране"                 as UC_SavePack
    usecase "Каталог наборів"           as UC_BrowsePacks
}

User  --> UC_CreatePack
User  --> UC_ManageCards
User  --> UC_EditPack
User  --> UC_PackCover
User  --> UC_ActivatePack
User  --> UC_PublishPack
User  --> UC_TrashPack
User  --> UC_RatePack
User  --> UC_SavePack
Guest --> UC_BrowsePacks

UC_PublishPack .> UC_ActivatePack : <<include>>
UC_PackCover   .> UC_EditPack     : <<extend>>


' ===========================================================================
' 4. Мапи
' ===========================================================================
rectangle "Мапи" as PKG_Maps {
    usecase "Створити мапу"             as UC_CreateMap
    usecase "Налаштувати поля"          as UC_ConfigFields
    usecase "Редагувати метадані"       as UC_EditMap
    usecase "Обкладинка мапи"           as UC_MapCover
    usecase "Активувати мапу"           as UC_ActivateMap
    usecase "Опублікувати мапу"         as UC_PublishMap
    usecase "Видалити/відновити"        as UC_TrashMap
    usecase "Оцінити мапу"              as UC_RateMap
    usecase "У вибране"                 as UC_SaveMap
    usecase "Каталог мап"               as UC_BrowseMaps
}

User  --> UC_CreateMap
User  --> UC_ConfigFields
User  --> UC_EditMap
User  --> UC_MapCover
User  --> UC_ActivateMap
User  --> UC_PublishMap
User  --> UC_TrashMap
User  --> UC_RateMap
User  --> UC_SaveMap
Guest --> UC_BrowseMaps

UC_CreateMap   .> UC_ConfigFields : <<include>>
UC_ActivateMap .> UC_ConfigFields : <<include>>
UC_PublishMap  .> UC_ActivateMap  : <<include>>
UC_MapCover    .> UC_EditMap      : <<extend>>


' ===========================================================================
' 5. Лобі та команди
' ===========================================================================
rectangle "Лобі та команди" as PKG_Lobby {
    usecase "Створити лобі"             as UC_CreateLobby
    usecase "Зайти як гість"            as UC_JoinAsGuest
    usecase "Зайти як користувач"       as UC_JoinAsUser
    usecase "Створити команду"          as UC_CreateTeam
    usecase "Редагувати команду"        as UC_EditTeam
    usecase "Видалити команду"          as UC_DeleteTeam
    usecase "Join / leave команди"      as UC_TeamJoinLeave
    usecase "Виганяти гравців"          as UC_Kick
    usecase "Закрити лобі"              as UC_CloseLobby
    usecase "Покинути лобі"             as UC_LeaveLobby
}

Host   --> UC_CreateLobby
Guest  --> UC_JoinAsGuest
User   --> UC_JoinAsUser
Host   --> UC_CreateTeam
Host   --> UC_EditTeam
Host   --> UC_DeleteTeam
Player --> UC_TeamJoinLeave
Host   --> UC_Kick
Host   --> UC_CloseLobby
Player --> UC_LeaveLobby


' ===========================================================================
' 6. Ігровий процес
' ===========================================================================
rectangle "Ігровий процес" as PKG_Game {
    usecase "Розпочати гру"             as UC_StartGame
    usecase "Розпочати хід"             as UC_StartTurn
    usecase "Відмічати картки"          as UC_GuessCards
    usecase "Підтвердити хід"           as UC_ReviewTurn
    usecase "Змінити рахунок"           as UC_AdjustScore
    usecase "Перезапустити хід"         as UC_RestartTurn
    usecase "Фінальний рахунок"         as UC_FinishGame
}

Host      --> UC_StartGame
Explainer --> UC_StartTurn
Explainer --> UC_GuessCards
Explainer --> UC_ReviewTurn
Host      --> UC_ReviewTurn
Host      --> UC_AdjustScore
Host      --> UC_RestartTurn
Player    --> UC_FinishGame

UC_ReviewTurn  .> UC_FinishGame  : <<extend>>
UC_RestartTurn .> UC_StartTurn   : <<extend>>


' ===========================================================================
' 7. Зв'язок у реальному часі
' ===========================================================================
rectangle "Real-time зв'язок" as PKG_Realtime {
    usecase "Sync стану (WS)"           as UC_RealtimeSync
    usecase "Перепідключення"           as UC_Reconnect
    usecase "Командний чат"             as UC_TeamChat
    usecase "Глобальний чат"            as UC_GlobalChat
}

Player --> UC_RealtimeSync
Player --> UC_Reconnect
Player --> UC_TeamChat
Player --> UC_GlobalChat


' ===========================================================================
' Layout: сітка 3 колонки × 3 ряди
'   col1        col2        col3
'   Auth        Packs       Lobby
'   Profile     Maps        Game
'                           Realtime
' ===========================================================================
PKG_Auth    -[hidden]right- PKG_Packs
PKG_Packs   -[hidden]right- PKG_Lobby

PKG_Auth    -[hidden]down-  PKG_Profile
PKG_Packs   -[hidden]down-  PKG_Maps
PKG_Lobby   -[hidden]down-  PKG_Game
PKG_Game    -[hidden]down-  PKG_Realtime


' ===========================================================================
' Компактний legend (тільки ролі, повний опис — у тексті документа)
' ===========================================================================
legend bottom
|= Актор          |= Роль |
| Гість           | Незареєстрований відвідувач |
| Користувач      | Авторизований власник профілю |
| Гравець         | Учасник лобі (гість або користувач) |
| Хост            | Творець лобі, модерує гру |
| Ведучий         | Гравець, що пояснює слова |
endlegend

@enduml
