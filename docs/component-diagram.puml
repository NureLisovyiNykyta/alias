@startuml component_diagram
' ============================================================
'   COMPONENT DIAGRAM — Alias Backend (FastAPI)
'   A4 Portrait — vertical layout
' ============================================================
skinparam backgroundColor #FEFEFE
skinparam dpi 150

skinparam component {
    BackgroundColor<<router>>   #B3D9FF
    BorderColor<<router>>       #3388CC
    BackgroundColor<<ws>>       #D5B3FF
    BorderColor<<ws>>           #7733CC
    BackgroundColor<<service>>  #FFE0B2
    BorderColor<<service>>      #E6930A
    BackgroundColor<<repo>>     #C8E6C9
    BorderColor<<repo>>         #43A047
    BackgroundColor<<model>>    #F8BBD0
    BorderColor<<model>>        #C62860
    BackgroundColor<<infra>>    #D5B3FF
    BorderColor<<infra>>        #7733CC
    BackgroundColor<<di>>       #E0E0E0
    BorderColor<<di>>           #757575
    FontSize 11
}

skinparam package {
    BackgroundColor #F5F5F5
    BorderColor #BDBDBD
    FontSize 11
    FontStyle bold
}

skinparam database {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontSize 11
}

skinparam cloud {
    BackgroundColor #FFF3E0
    BorderColor #E65100
    FontSize 11
}

skinparam arrow {
    Color #546E7A
    FontSize 9
}

skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontSize 9
}

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam linetype ortho

' ====================== ROW 1: CLIENTS ======================
actor "HTTP Client" as http_c
actor "WS Client"   as ws_c

' ====================== ROW 2: ROUTERS ======================
package "API Routers" as pkg_r {
    component "auth"       <<router>> as r_auth
    component "users"      <<router>> as r_users
    component "card_packs" <<router>> as r_cp
    component "cards"      <<router>> as r_cards
    component "rooms"      <<router>> as r_rooms
    component "teams"      <<router>> as r_teams
    component "maps"       <<router>> as r_maps
    component "map_fields" <<router>> as r_mf

    ' Робимо 2 рядки по 4 елементи для компактності
    r_auth -[hidden]right-> r_users
    r_users -[hidden]right-> r_cp
    r_cp -[hidden]right-> r_cards

    r_rooms -[hidden]right-> r_teams
    r_teams -[hidden]right-> r_maps
    r_maps -[hidden]right-> r_mf

    r_auth -[hidden]down-> r_rooms
}

component "ws/router" <<ws>> as ws_r

' ====================== ROW 3: DI ======================
component "dependencies.py «DI»" <<di>> as di

' ====================== ROW 4: SERVICES ======================
package "Services «Business Logic»" as pkg_s {
    component "RoomService"  <<service>> as s_room
    component "TeamService"  <<service>> as s_team
    component "AuthService"  <<service>> as s_auth
    component "UserService"  <<service>> as s_user
    component "CardPackService" <<service>> as s_cp
    component "CardService"  <<service>> as s_card
    component "MapService"   <<service>> as s_map
    component "MapFieldService" <<service>> as s_mf
    component "ImageService" <<service>> as s_img
    component "EmailService" <<service>> as s_email

    ' Робимо 3 рядки для компактності
    s_room -[hidden]right-> s_team
    s_team -[hidden]right-> s_auth
    s_auth -[hidden]right-> s_user

    s_cp -[hidden]right-> s_card
    s_card -[hidden]right-> s_map
    s_map -[hidden]right-> s_mf

    s_img -[hidden]right-> s_email

    ' Зв'язуємо рядки по вертикалі
    s_room -[hidden]down-> s_cp
    s_cp -[hidden]down-> s_img
}

' ====================== ROW 4 (right): WS INFRA ======================
component "ConnectionManager\n«singleton»" <<infra>> as cm
component "ServerEvent / ClientEvent" <<infra>> as ev

' ====================== ROW 5: REPOS ======================
package "Repositories «Data Access»" as pkg_repo {
    component "GameRepository" <<repo>> as rp_game
    component "MapRepository"  <<repo>> as rp_map
    component "CardRepository" <<repo>> as rp_card
}

' ====================== ROW 6: ORM MODELS ======================
package "ORM Models «SQLAlchemy»" as pkg_m {
    component "User"     <<model>> as m_user
    component "CardPack" <<model>> as m_cp
    component "Card"     <<model>> as m_card
    component "CardType" <<model>> as m_ct
    component "Map"      <<model>> as m_map
    component "MapField" <<model>> as m_mf

    ' Робимо рожевий блок стовпчиком (витягнутим по вертикалі)
    m_user -[hidden]down-> m_cp
    m_cp -[hidden]down-> m_card
    m_card -[hidden]down-> m_ct
    m_ct -[hidden]down-> m_map
    m_map -[hidden]down-> m_mf
}
' ====================== ROW 7: DATABASES ======================
database "PostgreSQL" as pg
database "Redis"      as redis
cloud "Cloudflare R2" as r2

' ================================================================
'   VERTICAL FLOW (top → bottom)
' ================================================================

http_c  -down-> pkg_r
ws_c    -down-> ws_r

pkg_r   -down-> di
ws_r    -down-> di

di      -down-> pkg_s
di      -down-> cm

pkg_s   -down-> pkg_repo

s_room  -up-> cm     : broadcast
s_team  -up-> cm     : broadcast

ws_r    -down-> cm
ws_r    -down-> rp_game

cm      -right-> ev

rp_game -down-> redis
rp_map  -down-> pg
rp_card -down-> pg

pkg_m   -down-> pg

s_img   -down-> r2

' ================================================================
'   HIDDEN LINKS for vertical alignment
' ================================================================
http_c  -[hidden]right-> ws_c
pg      -[hidden]right-> redis
redis   -[hidden]right-> r2

' ================================================================
'   NOTES
' ================================================================
note right of cm
  **REST → WS**
  HTTP handler → Service
  → Redis (GameRepo)
  → CM.broadcast()
  → WS-клієнти
end note

note bottom of redis
  room:<code> → JSON
  TTL: 7200/14400/900s
end note

@enduml