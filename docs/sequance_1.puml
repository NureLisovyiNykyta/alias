@startuml sequence_diagram
' ============================================================
'   SEQUENCE DIAGRAM — Alias Backend: Game Room Lifecycle
' ============================================================
skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 14

skinparam sequence {
    ArrowColor #37474F
    ArrowFontSize 14
    ArrowFontColor #37474F

    LifeLineBorderColor #78909C
    LifeLineBackgroundColor #ECEFF1

    ParticipantBorderColor #1565C0
    ParticipantBackgroundColor #E3F2FD
    ParticipantFontColor #0D47A1
    ParticipantFontSize 14
    ParticipantFontStyle bold

    ActorBorderColor #2E7D32
    ActorBackgroundColor #E8F5E9
    ActorFontColor #1B5E20
    ActorFontSize 14

    GroupBorderColor #B0BEC5
    GroupBackgroundColor #FAFAFA
    GroupHeaderFontSize 14

    DividerBorderColor #90A4AE
    DividerBackgroundColor #ECEFF1
    DividerFontStyle bold
    DividerFontSize 14
}

skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontSize 14
}

' =================== Participants ===================
actor       "Host\n(HTTP)" as Host   #E8F5E9
actor       "Player\n(HTTP)" as Player #FFF3E0
participant "rooms.py\n«Router»"      as Router  #B3D9FF
participant "teams.py\n«Router»"      as TRouter #B3D9FF
participant "RoomService"             as RS      #FFE0B2
participant "TeamService"             as TS      #FFE0B2
participant "MapRepository"           as MR      #C8E6C9
participant "CardRepository"          as CR      #C8E6C9
participant "GameRepository"          as GR      #C8E6C9
database    "PostgreSQL"              as PG      #E3F2FD
database    "Redis"                   as Redis   #E3F2FD
participant "ConnectionManager"       as CM      #D5B3FF
actor       "WS Clients\n(all in room)" as WSC   #F3E5F5

' =================== 1. CREATE ROOM ===================
== 1. Створення кімнати (POST /api/rooms/create) ==

Host -> Router ++ #B3D9FF : POST /api/rooms/create\n{map_id, room_name}
    Router -> RS ++ #FFE0B2 : create_room(request, host)
        RS -> MR ++ #C8E6C9 : get_map_with_relations(map_id)
            MR -> PG ++ : SELECT maps\nJOIN fields, card_packs, types
            return Map + Fields + CardPacks
        return MapInfo, CardPacksInfo

        RS -> RS : generate_room_code()
        RS -> RS : Player.create_from_user(host)
        RS -> RS : RoomStateJSON(status=LOBBY)

        RS -> GR ++ #C8E6C9 : create_room_if_not_exists(room)
            GR -> Redis ++ : SET room:<code> NX EX 7200
            return OK
        return true
    return RoomStateJSON
return 200 RoomStateJSON

|||

' =================== 2. JOIN ROOM ===================
== 2. Приєднання до кімнати (POST /api/rooms/join) ==

Player -> Router ++ #B3D9FF : POST /api/rooms/join\n{room_code, guest_id?}
    Router -> RS ++ #FFE0B2 : join_room(request, user|None)
        RS -> GR ++ #C8E6C9 : get_room(room_code)
            GR -> Redis ++ : GET room:<code>
            return JSON
        return RoomStateJSON

        alt user != None
            RS -> RS : Player.create_from_user(user)
        else guest
            RS -> RS : Player.create_guest(guest_id)
        end

        RS -> RS : room.players[id] = player

        RS -> GR ++ #C8E6C9 : save_room(room)
            GR -> Redis ++ : SET room:<code> EX 7200
            return OK
        return

        RS ->> CM ++ #D5B3FF : broadcast(room_code,\nServerEvent.player_joined)
            CM ->> WSC : send_text(JSON)\n<i>to all connected</i>
        return
    return RoomStateJSON
return 200 RoomStateJSON

|||

' =================== 3. CREATE TEAM ===================
== 3. Створення команди (POST /api/rooms/{code}/teams) ==

Host -> TRouter ++ #B3D9FF : POST /teams\n{name, color}
    TRouter -> TS ++ #FFE0B2 : create_team(room_code, name, color, host_id)
        TS -> GR ++ #C8E6C9 : get_room(room_code)
            GR -> Redis ++ : GET room:<code>
            return JSON
        return RoomStateJSON

        TS -> TS : validate host_id == room.host_id
        TS -> TS : Team(uuid4(), name, color)
        TS -> TS : room.teams[team_id] = team

        TS -> GR ++ #C8E6C9 : save_room(room)
            GR -> Redis ++ : SET room:<code> EX 7200
            return OK
        return

        TS ->> CM ++ #D5B3FF : broadcast(room_code,\nServerEvent.team_created)
            CM ->> WSC : send_text(JSON)
        return
    return Team
return 201 Team

|||

' =================== 4. JOIN TEAM ===================
== 4. Приєднання до команди (POST /teams/{id}/join) ==

Player -> TRouter ++ #B3D9FF : POST /teams/{id}/join\n{guest_id?}
    TRouter -> TS ++ #FFE0B2 : join_team(room_code, team_id, user, guest_id)
        TS -> GR ++ #C8E6C9 : get_room(room_code)
            GR -> Redis ++ : GET room:<code>
            return JSON
        return RoomStateJSON

        TS -> TS : resolve player_id
        TS -> TS : validate team exists\n& not full
        TS -> TS : remove from old team\nif needed
        TS -> TS : player.team_id = team_id\nteam.player_ids.append(id)

        TS -> GR ++ #C8E6C9 : save_room(room)
            GR -> Redis ++ : SET room:<code> EX 7200
            return OK
        return

        TS ->> CM ++ #D5B3FF : broadcast(room_code,\nServerEvent.player_team_changed)
            CM ->> WSC : send_text(JSON)
        return
    return
return 204

|||

' =================== 5. START GAME ===================
== 5. Старт гри (POST /api/rooms/{code}/start) ==

Host -> Router ++ #B3D9FF : POST /{code}/start
    Router -> RS ++ #FFE0B2 : start_game(room_code, host_id)
        RS -> GR ++ #C8E6C9 : get_room(room_code)
            GR -> Redis ++ : GET room:<code>
            return JSON
        return RoomStateJSON

        RS -> RS : validate: host, status,\nteams count, team sizes

        RS -> CR ++ #C8E6C9 : get_cards_for_packs(pack_ids)
            CR -> PG ++ : SELECT id, card_pack_id\nFROM cards WHERE pack_id IN(...)
            return rows
        return {pack_id: [card_ids]}

        RS -> RS : shuffle card_ids\nper each pack
        RS -> RS : room.card_queues = {...}
        RS -> RS : CurrentTurn(\n  team=first, phase=PREPARE\n)
        RS -> RS : room.status = PLAYING

        RS -> GR ++ #C8E6C9 : save_room(room)
            GR -> Redis ++ : SET room:<code> EX 14400
            return OK
        return

        RS ->> CM ++ #D5B3FF : broadcast(room_code,\nServerEvent.game_started)
            CM ->> WSC : send_text(JSON)\n<i>full RoomStateJSON</i>
        return
    return RoomStateJSON
return 200 RoomStateJSON

|||

' =================== 6. CLOSE ROOM ===================
== 6. Закриття кімнати (POST /api/rooms/{code}/close) ==

Host -> Router ++ #B3D9FF : POST /{code}/close
    Router -> RS ++ #FFE0B2 : close_room(room_code, host_id)
        RS -> GR ++ #C8E6C9 : get_room(room_code)
            GR -> Redis ++ : GET room:<code>
            return JSON
        return RoomStateJSON

        RS -> RS : validate host_id

        RS ->> CM ++ #D5B3FF : broadcast(room_code,\nServerEvent.room_closed)
            CM ->> WSC : send_text(JSON)
        return

        RS -> GR ++ #C8E6C9 : delete_room(room_code)
            GR -> Redis ++ : DEL room:<code>
            return OK
        return
    return
return 204

@endumlsequance_1.puml